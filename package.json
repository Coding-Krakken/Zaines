{
  "name": "zaines-stay-and-play",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.5",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint src scripts --ext .ts,.tsx,.js",
    "lint:agents": "node scripts/ci/enforce-agent-autonomy.cjs",
    "hooks:install": "git config core.hooksPath .githooks",
    "format:check": "pnpm dlx prettier@3.6.2 --check \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run test:app && pnpm run test:framework",
    "test:app": "vitest run",
    "test:framework": "pnpm --dir .github/framework test",
    "test:e2e": "PLAYWRIGHT_TEST=1 playwright test",
    "drain:emails": "node scripts/drain-email-queue.js",
    "test:watch": "vitest",
    "worker": "node scripts/worker.js",
    "audit:ui:accessibility": "node scripts/audit/accessibility_check.js",
    "audit:ui:accessibility:basic": "node scripts/audit/accessibility_basic_check.js",
    "audit:ui:accessibility:playwright": "node scripts/audit/playwright_a11y.js",
    "audit:issue66:performance": "node scripts/audit/issue66_performance_budget.js",
    "audit:issue66:security": "node scripts/audit/issue66_security_gate.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.8.0",
    "@stripe/react-stripe-js": "^5.6.1",
    "@stripe/stripe-js": "^8.11.0",
    "@vercel/blob": "^2.2.0",
    "bullmq": "^5.71.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "ioredis": "^5.10.1",
    "lucide-react": "^0.577.0",
    "next": "16.2.3",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "pg": "^8.18.0",
    "prisma": "^7.8.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^9.13.0",
    "react-dom": "19.2.4",
    "react-email": "^5.2.10",
    "react-hook-form": "^7.71.1",
    "resend": "^6.9.4",
    "signature_pad": "^5.1.3",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "4.0.18",
    "axe-core": "^4.11.1",
    "cheerio": "^1.2.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "hono": "^4.11.7",
      "lodash": "^4.17.23",
      "@types/pg": "8.11.11",
      "undici": "^6.24.0"
    }
  },
  "overrides": {
    "socket.io-parser": "^4.2.6"
  }
}
